# Copy this file to ".env.local" and paste your real keys after the = signs.
# Do NOT share .env.local or commit it to GitHub.

# --- Existing keys (unchanged) ----------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-key-here
TAVILY_API_KEY=your-tavily-key-here

# Research monitor storage (Upstash Redis) — existing
UPSTASH_REDIS_REST_URL=your-upstash-url-here
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Optional: protects the cron / run-now endpoints — existing
CRON_SECRET=your-cron-secret-here

# Sales pipeline password gate — existing (KEPT for now, do not remove)
SALES_PIPELINE_PASSWORD=your-team-password-here

# --- New for Founder OS V1 Phase 1 (Supabase) -------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
